+     modalidad    = `Modalidad de ejecución de la obra`,
+     fecha_inicio = dmy(`Fecha de inicio de obra`)  # formato dd/mm/yyyy
+   ) |>
+   filter(!is.na(fecha_inicio),
+          fecha_inicio >= inicio_periodo,
+          fecha_inicio <= fin_periodo)
> # Diagnóstico de cobertura (las obras sin fecha de inicio quedan fuera de la serie)
> message(sprintf("Obras con fecha de inicio en el período: %s de %s registros.",
