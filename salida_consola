> # ---- 4. Quiebre endógeno: strucchange (Bai-Perron) ---------------------------
> # Serie temporal mensual (frecuencia 12). Modelo de cambio de MEDIA (~ 1).
> y_ts <- ts(serie$prop_ad, start = c(year(min(serie$mes)),
+                                     month(min(serie$mes))), frequency = 12)
> # 4a. Test de estabilidad (supF de Andrews) y fecha de quiebre única
> fs <- Fstats(y_ts ~ 1)
> sctest(fs)                 # H0: sin quiebre

