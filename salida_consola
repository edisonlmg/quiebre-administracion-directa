+                 format(nrow(crudo),  big.mark = ",")))
Obras con fecha de inicio en el período: 117,339 de 191,180 registros.
> # ---- 2. Serie mensual --------------------------------------------------------
> # prop_ad = (obras AD iniciadas en el mes) / (todas las obras iniciadas en el mes)
> serie <- obras |>
+   mutate(
+     mes = floor_date(fecha_inicio, "month"),
+     es_ad = as.integer(modalidad == modalidad_objetivo)
+   ) |>
+   summarise(total = n(), ad = sum(es_ad), .by = mes) |>
+   arrange(mes) |>
+   complete(mes = seq(min(mes), max(mes), by = "month"),
+            fill = list(total = 0, ad = 0)) |>
+   mutate(
+     prop_ad = if_else(total > 0, ad / total, NA_real_),
+     t = row_number(),                                   # índice de tiempo
+     post = as.integer(mes >= fecha_vigencia),           # 1 desde la vigencia
+     t_post = post * (t - min(t[mes >= fecha_vigencia]) + 1)  # tiempo transcurrido tras la vigencia
+   )
> # ---- 3. Gráfico exploratorio de la serie ------------------------------------
> g_serie <- serie |>
+   tidyplot(x = mes, y = prop_ad) |>
+   add_line(color = col_teal, linewidth = 0.9) |>
+   add_data_points(color = col_teal, size = 1.2) |>
+   add_reference_lines(x = fecha_vigencia, color = col_marca) |>
+   add_title("Proporción mensual de obras por administración directa") |>
+   adjust_x_axis_title("Mes de inicio de obra") |>
